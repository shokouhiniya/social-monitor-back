APP_NAME=Social Monitor
NODE_ENV=development

HOST=127.0.0.1
PORT=3000

DB_CONNECTION=postgres
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=social_monitor
DB_NAME=social_monitor
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_AUTOLOADENTITIES=true

JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=60m

# Instagram API (RapidAPI)
RAPIDAPI_KEY=your_rapidapi_key_here

# OpenRouter (LLM)
OPENROUTER_API_KEY=your_openrouter_key_here

# Twitter API Providers (RapidAPI)
TWITTER_API_KEY_1=your_twitter_api_key_here
TWITTER_API_HOST_1=twitter241.p.rapidapi.com
TWITTER_API_KEY_2=your_twitter_api_key_here
TWITTER_API_HOST_2=twitter154.p.rapidapi.com
TWITTER_API_KEY_3=your_twitter_api_key_here
TWITTER_API_HOST_3=twitter-api45.p.rapidapi.com

# Telegram (from my.telegram.org)
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash
TELEGRAM_SESSION=your_session_string_from_telegram_auth_js
